// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model WebhookEvent {
  id          String   @id @default(cuid())
  topic       String
  shopDomain  String
  shopifyId   String   @unique
  payload     Json
  receivedAt  DateTime @default(now())
  processedAt DateTime?
  status      String   @default("received")
}

model Product {
  id         String   @id        // Shopify product ID
  shopDomain String
  payload    Json                // latest full product snapshot (used for diffing)
  updatedAt  DateTime @updatedAt
}

model ProductChangeLog {
  id          String   @id @default(cuid())
  shopifyId   String
  productTitle String
  field       String   // "title" | "status" | "price" | etc.
  oldValue    String?
  newValue    String
  changedAt   DateTime @default(now())
}

model FailedJob {
  id           String   @id @default(cuid())
  jobId        String
  queueName    String
  jobData      Json
  errorMessage String
  attemptsMade Int
  failedAt     DateTime @default(now())
}

model Subscription {
  id                    String    @id @default(cuid())
  shopDomain            String    @unique
  shopifyChargeId       String?   @unique
  plan                  String    @default("free")  // "free" | "basic" | "pro"
  status                String    @default("pending") // "pending" | "active" | "declined" | "expired" | "frozen" | "cancelled"
  accessToken           String?
  trialEndsAt           DateTime?
  billingStartsAt       DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}