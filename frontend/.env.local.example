# Shopify app API key — from Partners dashboard (safe to expose, used by App Bridge)
NEXT_PUBLIC_SHOPIFY_API_KEY=your_api_key_here

# Shopify app API secret — from Partners dashboard (server-side only, never expose)
# Used by the OAuth callback to validate HMAC + exchange the auth code for an access token
SHOPIFY_API_SECRET=your_api_secret_here

# NestJS backend URL
# Local dev: http://localhost:3000
# Production: your Railway service URL
NEXT_PUBLIC_API_URL=http://localhost:3000
